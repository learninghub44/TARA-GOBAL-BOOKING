# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment Providers
# Used to bill vendors for their TARA platform subscription. TARA does not
# process payment for bookings between customers and vendors - that happens
# directly between them off-platform.
# Paystack
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Pesapal
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_CALLBACK_URL=your_pesapal_callback_url
# 'live' for production, anything else (or unset) uses the sandbox API
PESAPAL_ENV=sandbox
# Optional: skip auto-registration by pre-registering an IPN URL in the
# Pesapal dashboard and pasting its ipn_id here. If unset, the app registers
# PESAPAL_IPN_URL (defaults to {NEXT_PUBLIC_APP_URL}/api/webhooks/subscription/pesapal)
# on first use and caches the id.
PESAPAL_IPN_ID=
PESAPAL_IPN_URL=your_pesapal_ipn_url

# M-Pesa (Safaricom Daraja API)
# 'live' for production, anything else (or unset) uses the sandbox API
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_CALLBACK_URL=your_mpesa_callback_url

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@tara.com

# KYC (Didit)
DIDIT_API_KEY=your_didit_api_key
DIDIT_API_SECRET=your_didit_api_secret
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET=tara-uploads

# WebRTC (TURN/STUN)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential
STUN_SERVER_URL=stun:your-stun-server.com:3478

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TARA
NEXT_PUBLIC_APP_DESCRIPTION=Tours • Travels • Rentals • Adventures

# AI Assistant (Groq)
GROQ_API_KEY=your_groq_api_key_here
AI_ASSISTANT_DAILY_LIMIT=50
AI_ASSISTANT_RATE_LIMIT=10

# Security
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Cron (used by /api/cron/subscriptions and /api/admin/payments/reconcile
# when called from a scheduler rather than the admin dashboard). Send as
# header: x-cron-secret: $CRON_SECRET
CRON_SECRET=your_cron_secret
